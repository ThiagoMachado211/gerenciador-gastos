<div class="auth-card">
  <div class="auth-logo-mark" aria-hidden="true">
    <svg viewBox="0 0 24 24">
      <path d="M6 15l4-4 3 3 5-5"></path>
      <path d="M15 9h3v3"></path>
    </svg>
  </div>

  <div class="auth-brand">flux<em>o</em></div>
  <div class="auth-tagline">Controle financeiro com clareza e precisão.</div>

  <div class="auth-tabs">
    <span class="auth-tab active">Entrar</span>
    <%= link_to "Criar conta", new_registration_path(resource_name), class: "auth-tab" %>
  </div>

  <% if flash[:alert].present? %>
    <div class="auth-alert"><%= flash[:alert] %></div>
  <% end %>

  <% if flash[:notice].present? %>
    <div class="auth-notice"><%= flash[:notice] %></div>
  <% end %>

  <% if resource.errors.any? %>
    <div class="auth-errors">
      <strong>Não foi possível entrar.</strong>
      <ul>
        <% resource.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
    <div class="auth-field">
      <%= f.label :email, "E-mail", class: "auth-label" %>
      <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            class: "auth-input",
            placeholder: "seu@email.com" %>
    </div>

    <div class="auth-field">
      <%= f.label :password, "Senha", class: "auth-label" %>
      <%= f.password_field :password,
            autocomplete: "current-password",
            class: "auth-input",
            placeholder: "••••••••" %>
    </div>

    <div class="auth-check-row">
      <% if devise_mapping.rememberable? %>
        <label class="auth-check">
          <%= f.check_box :remember_me %>
          <span>Lembrar de mim</span>
        </label>
      <% else %>
        <span></span>
      <% end %>

      <%= link_to "Esqueci minha senha", new_password_path(resource_name), class: "auth-link-subtle" %>
    </div>

    <%= f.submit "Entrar", class: "auth-submit" %>
  <% end %>

  <div class="auth-footer-link">
    Não tem conta?
    <%= link_to "Cadastre-se", new_registration_path(resource_name) %>
  </div>
</div>