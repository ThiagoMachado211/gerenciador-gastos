<%= form_with model: [:users, transaction] do |f| %>
  <%= render "shared/form_errors", object: transaction %>

  <div class="form-grid">
    <div class="form-field">
      <%= f.label :kind, "Tipo", class: "form-label" %>

      <%= f.select :kind,
                   [["Despesa", "expense"], ["Receita", "income"]],
                   {},
                   class: "form-select" %>
    </div>

    <div class="form-field">
      <%= f.label :occurred_on, "Data", class: "form-label" %>

      <%= f.date_field :occurred_on,
                       class: "form-input" %>
    </div>

    <div class="form-field form-field--full">
      <%= f.label :description, "Descrição", class: "form-label" %>

      <%= f.text_field :description,
                       placeholder: "Ex: Supermercado",
                       class: "form-input" %>
    </div>

    <div class="form-field">
      <%= f.label :amount_cents,
                  "Valor em centavos",
                  class: "form-label" %>

      <%= f.number_field :amount_cents,
                         min: 1,
                         step: 1,
                         placeholder: "Ex: 25000 para R$ 250,00",
                         class: "form-input" %>

      <span class="form-help">
        R$ 250,00 corresponde a 25000 centavos.
      </span>
    </div>

    <div class="form-field">
      <%= f.label :installments_count, "Parcelas", class: "form-label" %>

      <%= f.number_field :installments_count,
                         min: 1,
                         max: 36,
                         class: "form-input" %>
    </div>

    <div class="form-field">
      <%= f.label :category_id, "Categoria", class: "form-label" %>

      <%= f.collection_select :category_id,
                              @categories,
                              :id,
                              :name,
                              { prompt: "Selecione uma categoria" },
                              class: "form-select" %>
    </div>

    <div class="form-field">
      <%= f.label :credit_card_id, "Cartão", class: "form-label" %>

      <%= f.collection_select :credit_card_id,
                              @credit_cards,
                              :id,
                              :name,
                              { include_blank: "Nenhum cartão" },
                              class: "form-select" %>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit "Salvar transação",
                 class: "button button--primary" %>

    <%= link_to "Cancelar",
                users_transactions_path,
                class: "button button--secondary" %>
  </div>
<% end %>