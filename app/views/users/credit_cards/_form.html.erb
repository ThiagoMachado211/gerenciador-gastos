<%= form_with model: [:users, credit_card] do |f| %>
  <%= render "shared/form_errors", object: credit_card %>

  <div class="form-grid">
    <div class="form-field form-field--full">
      <%= f.label :name, "Nome do cartão", class: "form-label" %>

      <%= f.text_field :name,
                       placeholder: "Ex: Nubank",
                       autocomplete: "off",
                       class: "form-input" %>
    </div>

    <div class="form-field form-field--full">
      <%= f.label :limit_cents,
                  "Limite em centavos",
                  class: "form-label" %>

      <%= f.number_field :limit_cents,
                         min: 0,
                         step: 1,
                         placeholder: "Ex: 500000 para R$ 5.000,00",
                         class: "form-input" %>

      <span class="form-help">
        Informe o valor em centavos. Exemplo: R$ 5.000,00 corresponde a 500000.
      </span>
    </div>

    <div class="form-field">
      <%= f.label :closing_day,
                  "Dia de fechamento",
                  class: "form-label" %>

      <%= f.number_field :closing_day,
                         min: 1,
                         max: 31,
                         placeholder: "Ex: 5",
                         class: "form-input" %>
    </div>

    <div class="form-field">
      <%= f.label :due_day,
                  "Dia de vencimento",
                  class: "form-label" %>

      <%= f.number_field :due_day,
                         min: 1,
                         max: 31,
                         placeholder: "Ex: 12",
                         class: "form-input" %>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit "Salvar cartão",
                 class: "button button--primary" %>

    <%= link_to "Cancelar",
                users_credit_cards_path,
                class: "button button--secondary" %>
  </div>
<% end %>