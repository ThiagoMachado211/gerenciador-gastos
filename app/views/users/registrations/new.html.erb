<div class="auth-card">
  <div class="auth-brand">
    <div class="auth-brand__icon">
      ↗
    </div>

    <div class="auth-brand__text">
      <h1><span>flu</span>xo</h1>
      <p>Controle financeiro com clareza e precisão.</p>
    </div>
  </div>

  <div class="auth-tabs">
    <%= link_to "Entrar", new_user_session_path, class: "auth-tab" %>
    <%= link_to "Criar conta", new_user_registration_path, class: "auth-tab auth-tab--active" %>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
    <div class="auth-field">
      <%= f.label :name, "Nome completo" %>
      <%= f.text_field :name, autofocus: true, placeholder: "Seu nome" %>
    </div>

    <div class="auth-field">
      <%= f.label :email, "E-mail" %>
      <%= f.email_field :email, autocomplete: "email", placeholder: "seu@email.com" %>
    </div>

    <div class="auth-field">
      <%= f.label :password, "Senha" %>
      <%= f.password_field :password, autocomplete: "new-password", placeholder: "Min. 6 caracteres" %>
    </div>

    <%= f.submit "Criar conta grátis", class: "auth-submit" %>
  <% end %>

  <p class="auth-footer-link">
    Já tem conta?
    <%= link_to "Entrar", new_user_session_path %>
  </p>
</div>