<%= render "shared/page_header",
           eyebrow: "Visão geral",
           title: "Olá, #{current_user.name.presence || current_user.email}",
           description: "Acompanhe o resumo da sua vida financeira.",
           action_text: "Nova transação",
           action_path: new_users_transaction_path %>

<div class="metrics-grid">
  <%= render "shared/metric_card",
             label: "Saldo do mês",
             value: "R$ 0,00",
             subtitle: "Receitas menos gastos",
             variant: "success" %>

  <%= render "shared/metric_card",
             label: "Receitas",
             value: "R$ 0,00",
             subtitle: "Nenhuma entrada",
             variant: "success" %>

  <%= render "shared/metric_card",
             label: "Gastos",
             value: "R$ 0,00",
             subtitle: "Nenhuma saída",
             variant: "danger" %>
</div>

<%= render "shared/panel",
           title: "Transações recentes",
           description: "Últimos lançamentos registrados." do %>

  <%= render "shared/empty_state",
             icon: "💳",
             title: "Nenhuma transação cadastrada",
             description: "Registre uma receita ou despesa para começar a acompanhar suas finanças.",
             action_text: "Criar primeira transação",
             action_path: new_users_transaction_path %>
<% end %>